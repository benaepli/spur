type Value = int;

role Head {
    var db: map<string, Value> = {"hi": 0};

    async fn Write(key: string, value: int): bool {
        db = db[key] := value;
        return true;
    }

    async fn Read(key: string): Value {
        return db[key];
    }
}

ClientInterface {
    async fn write(node: Head, key: string, value: Value) {
        <-node->Write(key, value);
    }

    async fn read(node: Head, key: string): Value {
        return <-node->Read(key);
    }
}